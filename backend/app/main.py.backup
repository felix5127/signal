@app.get("/api/signals/{signal_id}/deep-research")
async def get_deep_research(signal_id: int, db: Session = Depends(get_db)):
    """
    获取信号的深度研究报告

    Args:
        signal_id: 信号 ID
        db: 数据库会话

    Returns:
        深度研究报告内容（Markdown 格式）
    """
    signal = db.query(Signal).filter(Signal.id == signal_id).first()
    if not signal:
        raise HTTPException(status_code=404, detail="Signal not found")

    if not signal.deep_dive:
        raise HTTPException(
            status_code=404, detail="Deep research report not generated yet"
        )

    return {
        "signal_id": signal.id,
        "title": signal.title,
        "content": signal.deep_dive,
        "generated_at": signal.deep_dive_generated_at.isoformat()
        if signal.deep_dive_generated_at
        else None,
        "tokens_used": signal.deep_dive_tokens,
        "cost_usd": signal.deep_dive_cost,
        "strategy": signal.deep_dive_strategy,
        "sources": json.loads(signal.deep_dive_sources) if signal.deep_dive_sources else [],
        "metadata": json.loads(signal.deep_dive_metadata)
        if signal.deep_dive_metadata
        else {},
    }


async def _generate_deep_research_background(signal_id: int, strategy: str):
    """后台任务：生成深度研究报告"""
    from app.services.deep_research_service import (
        DeepResearchService,
        ResearchStrategy,
    )

    db = SessionLocal()
    try:
        signal = db.query(Signal).filter(Signal.id == signal_id).first()
        if not signal:
            print(f"[DeepResearch] Signal {signal_id} not found")
            return

        # 初始化服务
        service = DeepResearchService()

        # 解析策略
        strategy_enum = ResearchStrategy(strategy)

        # 生成报告
        print(f"[DeepResearch] Starting background task for signal {signal_id}")
        await service.generate_research(
            signal=signal, strategy=strategy_enum, force_regenerate=True
        )
        print(f"[DeepResearch] Completed for signal {signal_id}")

    except Exception as e:
        print(f"[DeepResearch] Error for signal {signal_id}: {e}")
        import traceback

        traceback.print_exc()
    finally:
        db.close()


@app.post("/api/signals/{signal_id}/deep-research")
async def generate_deep_research(
    signal_id: int,
    background_tasks: BackgroundTasks,
    strategy: str = Query(default="lightweight", pattern="^(lightweight|full_agent|auto)$"),
    force: bool = Query(default=False),
    db: Session = Depends(get_db),
):
    """
    生成深度研究报告（后台异步执行）

    Args:
        signal_id: 信号 ID
        background_tasks: FastAPI 后台任务
        strategy: 研究策略 (lightweight/full_agent/auto)
        force: 强制重新生成，忽略缓存
        db: 数据库会话

    Returns:
        任务状态信息
    """
    signal = db.query(Signal).filter(Signal.id == signal_id).first()
    if not signal:
        raise HTTPException(status_code=404, detail="Signal not found")

    # 检查缓存
    if not force and signal.deep_dive and signal.deep_dive_generated_at:
        cache_age = datetime.now() - signal.deep_dive_generated_at
        cache_hours = config.deep_research.cache_duration_hours

        if cache_age.total_seconds() < cache_hours * 3600:
            return {
                "status": "cached",
                "message": "Report already exists and is still fresh",
                "signal_id": signal.id,
                "generated_at": signal.deep_dive_generated_at.isoformat(),
                "cache_age_hours": cache_age.total_seconds() / 3600,
            }

    # 添加后台任务
    background_tasks.add_task(_generate_deep_research_background, signal_id, strategy)

    return {
        "status": "processing",
        "message": "Deep research report generation started in background",
        "signal_id": signal.id,
        "strategy": strategy,
        "estimated_time_seconds": "60-120",
    }



if __name__ == "__main__":
    import uvicorn

    uvicorn.run(app, host="0.0.0.0", port=8000)
