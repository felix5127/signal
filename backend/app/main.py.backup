@app.post("/api/generate-newsletter")
async def trigger_newsletter(
    force: bool = Query(default=False, description="是否强制重新生成"),
    db: Session = Depends(get_db),
):
    """
    手动触发生成周刊

    用于测试和手动生成周刊

    Args:
        force: 是否强制重新生成（忽略已存在的周刊）
        db: 数据库会话

    Returns:
        生成结果
    """
    from app.tasks.newsletter import generate_weekly_newsletter

    try:
        newsletter = await generate_weekly_newsletter(force_regenerate=force)

        if newsletter:
            return {
                "status": "success",
                "message": "周刊生成成功",
                "newsletter": {
                    "id": newsletter.id,
                    "title": newsletter.title,
                    "year": newsletter.year,
                    "week_number": newsletter.week_number,
                    "resource_count": len(newsletter.resource_ids) if newsletter.resource_ids else 0,
                    "published_at": newsletter.published_at.isoformat() if newsletter.published_at else None,
                },
            }
        else:
            return {
                "status": "skipped",
                "message": "本周无需生成（已存在或无符合条件的内容）",
            }

    except Exception as e:
        return {"status": "error", "message": str(e)}


@app.get("/api/newsletters")
async def get_newsletters(
    limit: int = Query(default=10, ge=1, le=52),
    offset: int = Query(default=0, ge=0),
    year: Optional[int] = Query(default=None),
    db: Session = Depends(get_db),
):
    """
    获取周刊列表

    Args:
        limit: 每页数量
        offset: 偏移量
        year: 年份筛选（可选）
        db: 数据库会话

    Returns:
        周刊列表 + 分页信息
    """
    from app.models.newsletter import Newsletter

    query = db.query(Newsletter)

    if year:
        query = query.filter(Newsletter.year == year)

    total = query.count()
    items = query.order_by(Newsletter.year.desc(), Newsletter.week_number.desc()).offset(offset).limit(limit).all()

    items_dict = []
    for item in items:
        items_dict.append({
            "id": item.id,
            "title": item.title,
            "year": item.year,
            "week_number": item.week_number,
            "resource_count": len(item.resource_ids) if item.resource_ids else 0,
            "published_at": item.published_at.isoformat() if item.published_at else None,
            "created_at": item.created_at.isoformat() if item.created_at else None,
        })

    return {"items": items_dict, "total": total, "limit": limit, "offset": offset}


