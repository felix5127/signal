# Input: 环境变量 (OPENAI_API_KEY), config.yaml
# Output: FastAPI 应用实例，提供 HTTP API 服务
# Position: 系统核心入口，串联所有模块
# 更新提醒：一旦我被更新，务必更新我的开头注释，以及所属的文件夹的 md

from datetime import datetime
from typing import Optional
import json

try:
    from apscheduler.schedulers.background import BackgroundScheduler
    SCHEDULER_AVAILABLE = True
except ImportError:
    SCHEDULER_AVAILABLE = False
    BackgroundScheduler = None  # type: ignore
from fastapi import BackgroundTasks, Depends, FastAPI, HTTPException, Query
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse
from sqlalchemy.orm import Session

from app.config import config
from app.database import SessionLocal, get_db
from app.models.signal import Signal
from app.models.resource import Resource
from app.tasks.pipeline import run_full_pipeline
from app.utils.cache import redis_cache

# 导入新的API路由
from app.api.digest import router as digest_router
from app.api.resources import router as resources_router
from app.api.feeds import router as feeds_router
from app.api.sources import router as sources_router


# 自定义 JSON 响应类，确保中文正确显示
class PrettyJSONResponse(JSONResponse):
    def render(self, content) -> bytes:
        return json.dumps(
            content,
            ensure_ascii=False,  # 中文不转义
            allow_nan=False,
            indent=None,
            separators=(",", ":"),
        ).encode("utf-8")


app = FastAPI(
    title="AI Signal Hunter API",
    description="面向超级个体的技术情报分析系统",
    version="0.1.0",
    default_response_class=PrettyJSONResponse,
)

# 注册路由
app.include_router(digest_router, prefix="/api", tags=["digest"])
app.include_router(resources_router, prefix="/api", tags=["resources"])
app.include_router(feeds_router, prefix="/api/feeds", tags=["feeds"])
app.include_router(sources_router, prefix="/api/sources", tags=["sources"])

# CORS 配置（允许前端访问）
# 注意：allow_origins 不支持通配符子域名，需要使用 allow_origin_regex
app.add_middleware(
    CORSMiddleware,
    allow_origins=[
        "http://localhost:3000",
        "http://frontend:3000",
        "https://signal.felixwithai.com",  # 自定义域名
        "https://felixwithai.com",  # 根域名
    ],
    allow_origin_regex=r"https://.*\.vercel\.app",  # 匹配所有 Vercel 预览域名
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# APScheduler 定时任务
if SCHEDULER_AVAILABLE:
    scheduler = BackgroundScheduler()
else:
    scheduler = None
last_run_time: Optional[datetime] = None
next_run_time: Optional[datetime] = None


@app.get("/")
async def root():
    """根路径 - Hello World"""
    return {
        "message": "Welcome to AI Signal Hunter API",
        "status": "running",
        "version": "0.1.0",
    }


@app.get("/health")
async def health_check():
    """健康检查端点"""
    # 检查数据库连接
    db_status = "ok"
    try:
        from sqlalchemy import text
        db = SessionLocal()
        db.execute(text("SELECT 1"))
        db.close()
    except Exception as e:
        db_status = f"error: {str(e)}"

    return {
        "status": "ok",
        "service": "signal-hunter-backend",
        "database": db_status,
        "last_run": last_run_time.isoformat() if last_run_time else None,
        "next_run": next_run_time.isoformat() if next_run_time else None,
    }


@app.get("/api/signals")
async def get_signals(
    limit: int = Query(default=20, ge=1, le=100),
    offset: int = Query(default=0, ge=0),
    min_score: Optional[int] = Query(default=None, ge=1, le=5),
    source: Optional[str] = Query(default=None),
    sources: Optional[str] = Query(default=None),  # 新增：多数据源筛选（逗号分隔）
    category: Optional[str] = Query(default=None),
    search: Optional[str] = Query(default=None),
    sort_by: str = Query(default="created_at", pattern="^(created_at|final_score)$"),
    db: Session = Depends(get_db),
):
    """
    获取信号列表

    Args:
        limit: 每页数量（1-100）
        offset: 偏移量
        min_score: 最低评分（1-5）
        source: 数据源过滤（单个，兼容旧版）
        sources: 数据源过滤（多个，逗号分隔，如 "hn,github,huggingface"）
        category: 分类过滤
        search: 搜索关键词（标题/摘要）
        sort_by: 排序字段（created_at/final_score）
        db: 数据库会话

    Returns:
        信号列表 + 分页信息
    """
    # 构建查询
    query = db.query(Signal).filter(Signal.status == "published")

    # 过滤条件
    if min_score:
        query = query.filter(Signal.final_score >= min_score)

    # 数据源筛选（支持单个或多个）
    if sources:
        source_list = [s.strip() for s in sources.split(",") if s.strip()]
        if source_list:
            query = query.filter(Signal.source.in_(source_list))
    elif source:
        query = query.filter(Signal.source == source)

    if category:
        query = query.filter(Signal.category == category)
    if search:
        # 搜索标题或摘要
        search_pattern = f"%{search}%"
        query = query.filter(
            (Signal.title.ilike(search_pattern)) | (Signal.summary.ilike(search_pattern))
        )

    # 总数
    total = query.count()

    # 排序
    if sort_by == "final_score":
        query = query.order_by(Signal.final_score.desc(), Signal.created_at.desc())
    else:
        query = query.order_by(Signal.created_at.desc())

    # 分页
    items = query.offset(offset).limit(limit).all()

    # 转换为字典
    items_dict = []
    for item in items:
        # 安全解析 source_metadata（可能格式不正确）
        metadata = {}
        if item.source_metadata:
            try:
                metadata = json.loads(item.source_metadata)
            except (json.JSONDecodeError, TypeError):
                # 如果解析失败，使用空字典
                metadata = {}

        items_dict.append({
            "id": item.id,
            "source": item.source,
            "title": item.title,
            "url": item.url,
            "one_liner": item.one_liner,
            "summary": item.summary,
            "final_score": item.final_score,
            "heat_score": item.heat_score,
            "quality_score": item.quality_score,
            "category": item.category,
            "tags": item.tags.split(",") if item.tags else [],
            "source_metadata": metadata,
            "created_at": item.created_at.isoformat() if item.created_at else None,
        })

    return {"items": items_dict, "total": total, "limit": limit, "offset": offset}


@app.get("/api/signals/{signal_id}")
async def get_signal(signal_id: int, db: Session = Depends(get_db)):
    """
    获取单个信号详情

    Args:
        signal_id: 信号 ID
        db: 数据库会话

    Returns:
        信号详情
    """
    signal = db.query(Signal).filter(Signal.id == signal_id).first()
    if not signal:
        return {"error": "Signal not found"}, 404

    return {
        "id": signal.id,
        "source": signal.source,
        "title": signal.title,
        "url": signal.url,
        "one_liner": signal.one_liner,
        "summary": signal.summary,
        "final_score": signal.final_score,
        "heat_score": signal.heat_score,
        "quality_score": signal.quality_score,
        "category": signal.category,
        "tags": signal.tags.split(",") if signal.tags else [],
        "matched_conditions": signal.matched_conditions.split(",")
        if signal.matched_conditions
        else [],
        "source_metadata": json.loads(signal.source_metadata) if signal.source_metadata else {},
        "created_at": signal.created_at.isoformat() if signal.created_at else None,
        "source_created_at": signal.source_created_at.isoformat()
        if signal.source_created_at
        else None,
    }


@app.get("/api/resources/{resource_id}")
async def get_resource(resource_id: int, db: Session = Depends(get_db)):
    """
    获取单个资源详情

    Args:
        resource_id: 资源 ID
        db: 数据库会话

    Returns:
        资源详情（含LLM分析结果）
    """
    resource = db.query(Resource).filter(Resource.id == resource_id).first()
    if not resource:
        raise HTTPException(status_code=404, detail="Resource not found")

    return {
        "id": resource.id,
        "type": resource.type,
        "source_name": resource.source_name,
        "source_url": resource.source_url,
        "url": resource.url,
        "title": resource.title,
        "title_translated": resource.title_translated,
        "author": resource.author,
        "word_count": resource.word_count,
        "read_time": resource.read_time,
        "one_sentence_summary": resource.one_sentence_summary,
        "one_sentence_summary_zh": resource.one_sentence_summary_zh,
        "summary": resource.summary,
        "summary_zh": resource.summary_zh,
        "main_points": resource.main_points,
        "main_points_zh": resource.main_points_zh,
        "key_quotes": resource.key_quotes,
        "key_quotes_zh": resource.key_quotes_zh,
        "domain": resource.domain,
        "subdomain": resource.subdomain,
        "tags": resource.tags if resource.tags else [],
        "score": resource.score,
        "is_featured": resource.is_featured,
        "language": resource.language,
        "status": resource.status,
        "published_at": resource.published_at.isoformat() if resource.published_at else None,
        "created_at": resource.created_at.isoformat() if resource.created_at else None,
        "analyzed_at": resource.analyzed_at.isoformat() if resource.analyzed_at else None,
    }


@app.get("/api/stats")
async def get_stats(db: Session = Depends(get_db)):
    """
    获取统计数据

    Returns:
        统计信息
    """
    from sqlalchemy import func

    # 总信号数
    total_signals = db.query(Signal).filter(Signal.status == "published").count()

    # 按来源统计
    by_source = (
        db.query(Signal.source, func.count(Signal.id).label("count"))
        .filter(Signal.status == "published")
        .group_by(Signal.source)
        .all()
    )
    source_stats = {row.source: row.count for row in by_source}

    # 按分类统计
    by_category = (
        db.query(Signal.category, func.count(Signal.id).label("count"))
        .filter(Signal.status == "published")
        .group_by(Signal.category)
        .all()
    )
    category_stats = {row.category: row.count for row in by_category}

    # 按评分统计
    by_score = (
        db.query(Signal.final_score, func.count(Signal.id).label("count"))
        .filter(Signal.status == "published")
        .group_by(Signal.final_score)
        .order_by(Signal.final_score.desc())
        .all()
    )
    score_stats = {row.final_score: row.count for row in by_score}

    # 平均评分
    avg_scores = db.query(
        func.avg(Signal.heat_score).label("avg_heat"),
        func.avg(Signal.quality_score).label("avg_quality"),
        func.avg(Signal.final_score).label("avg_final"),
    ).first()

    # 最新更新时间
    latest_signal = (
        db.query(Signal)
        .filter(Signal.status == "published")
        .order_by(Signal.created_at.desc())
        .first()
    )

    return {
        "total_signals": total_signals,
        "by_source": source_stats,
        "by_category": category_stats,
        "by_score": score_stats,
        "average_scores": {
            "heat": round(avg_scores.avg_heat, 2) if avg_scores.avg_heat else 0,
            "quality": round(avg_scores.avg_quality, 2) if avg_scores.avg_quality else 0,
            "final": round(avg_scores.avg_final, 2) if avg_scores.avg_final else 0,
        },
        "latest_update": latest_signal.created_at.isoformat()
        if latest_signal
        else None,
        "scheduler": {
            "last_run": last_run_time.isoformat() if last_run_time else None,
            "next_run": next_run_time.isoformat() if next_run_time else None,
        },
    }


@app.post("/api/trigger-pipeline")
async def trigger_pipeline():
    """
    手动触发流水线

    用于测试和手动刷新数据
    """
    global last_run_time

    try:
        stats = await run_full_pipeline()
        last_run_time = datetime.now()

        return {
            "status": "success",
            "stats": {
                "scraped": stats.scraped_count,
                "filtered": stats.filtered_count,
                "generated": stats.generated_count,
                "saved": stats.saved_count,
                "failed": stats.failed_count,
                "total_tokens": stats.total_input_tokens + stats.total_output_tokens,
            },
            "run_time": last_run_time.isoformat(),
        }
    except Exception as e:
        return {"status": "error", "message": str(e)}


@app.post("/api/trigger-twitter")
async def trigger_twitter():
    """
    手动触发 Twitter 推文抓取（跳过 LLM，直接保存）

    用于测试和手动刷新推文数据
    """
    try:
        from app.tasks.pipeline import run_twitter_pipeline

        stats = await run_twitter_pipeline()

        return {
            "status": "success",
            "stats": {
                "scraped": stats.scraped_count,
                "duplicates": stats.scraped_count - stats.saved_count,
                "saved": stats.saved_count,
                "failed": stats.failed_count,
            },
        }
    except Exception as e:
        return {"status": "error", "message": str(e)}


