# ========================================
# Signal - 环境变量配置模板
# ========================================
#
# 使用说明:
# 1. 复制本文件为 .env: cp .env.example .env
# 2. 填写你的实际 API Keys
# 3. 启动服务: docker-compose up --build
#
# ⚠️ 注意: .env 文件包含敏感信息,已在 .gitignore 中排除,不会提交到 Git
#

# ========================================
# API Keys (必须)
# ========================================

# OpenRouter API Key (用于LLM调用)
# 获取地址: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here

# Tavily Search API Key (Deep Research功能需要)
# 获取地址: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# GitHub Token (可选，用于提高 GitHub API 限额)
# 获取地址: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_your-github-token-here

# Jina Reader API Key (可选，免费额度足够)
# 获取地址: https://jina.ai
JINA_API_KEY=jina_your-jina-api-key-here

# ========================================
# LLM 配置 (必须 - 与Railway云端保持一致)
# ========================================

# LLM 提供商: openrouter | openai | kimi | anthropic | ollama
LLM_PROVIDER=openrouter

# LLM 模型名称 (OpenRouter格式: provider/model)
# 推荐模型:
#   - anthropic/claude-3.5-sonnet (高质量,稍贵)
#   - openai/gpt-4o-mini (性价比高)
#   - google/gemini-2.0-flash-exp (免费额度)
LLM_MODEL=anthropic/claude-3.5-sonnet

# LLM API 基础URL (OpenRouter专用)
LLM_BASE_URL=https://openrouter.ai/api/v1

# LLM 超时时间 (秒)
LLM_TIMEOUT=60

# LLM 最大Token数
LLM_MAX_TOKENS=16000

# LLM 温度参数 (0-1, 越低越确定)
LLM_TEMPERATURE=0.3

# ========================================
# 数据库配置
# ========================================

# Docker 环境 (推荐，与 docker-compose.yml 一致)
DATABASE_URL=postgresql://signal_user:signal_pass@db:5432/signal_db
REDIS_URL=redis://redis:6379/0

# 本地开发 (不使用 Docker 时取消注释以下两行)
# DATABASE_URL=postgresql://localhost:5432/signal_db
# REDIS_URL=redis://localhost:6379/0

# SQLite (仅用于快速测试，不推荐生产使用)
# DATABASE_URL=sqlite:///./data/signals.db

# ========================================
# 日志配置
# ========================================

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ========================================
# 前端配置 (本地开发)
# ========================================

# 前端 API 地址
# 本地开发: http://localhost:8000
# 云端部署: https://your-backend-url.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ========================================
# Admin 后台配置
# ========================================

# 管理后台密码 (访问 /admin/* 需要)
ADMIN_PASSWORD=512780808

# ========================================
# R2/S3 文件存储配置 (研究助手功能需要)
# ========================================

# Cloudflare R2 端点 URL
# 格式: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# R2 Access Key ID (在 Cloudflare R2 控制台创建 API Token)
R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 Bucket 名称
R2_BUCKET_NAME=signal-research

# R2 公开访问 URL (可选，用于公开文件直接访问)
# R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ========================================
# 研究助手 AI API Keys (研究助手功能需要)
# ========================================

# Kimi K2 API Key (用于研究 Agent)
# 获取地址: https://platform.moonshot.cn
KIMI_API_KEY=sk-your-kimi-api-key-here

# 阿里云百炼 API Key (用于嵌入模型/TTS)
# 获取地址: https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
